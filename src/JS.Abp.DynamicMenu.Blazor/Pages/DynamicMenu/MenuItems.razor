                    </Field>
                    
                    <Validation>
                        <Field>
                            <FieldLabel>@L["Name"] *</FieldLabel>
                            <TextInput @bind-Value="@EditingMenuItem.Name" MaxLength="MenuItemConsts.NameMaxLength">
