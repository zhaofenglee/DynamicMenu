                    <Validation>
                        <Field>
                            <FieldLabel>@L["Url"]</FieldLabel>
                            <TextInput @bind-Value="@EditingMenuItem.Url" >
                                <Feedback>
                                    <ValidationError />
                                </Feedback>
                            </TextInput>
                        </Field>
                    </Validation>


                    <Validation>
                        <Field>
                            <FieldLabel>@L["Icon"]</FieldLabel>
                            <TextInput @bind-Value="@EditingMenuItem.Icon" MaxLength="MenuItemConsts.IconMaxLength">
