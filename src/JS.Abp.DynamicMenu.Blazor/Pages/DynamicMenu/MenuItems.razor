                     </Validation>


                    <Validation>
                        <Field>
                            <FieldLabel>@L["Target"]</FieldLabel>
                            <TextInput @bind-Value="@EditingMenuItem.Target" >
                                <Feedback>
                                    <ValidationError />
                                </Feedback>
                            </TextInput>
                        </Field>
                    </Validation>


                    <Validation>
                        <Field>
                            <FieldLabel>@L["ElementId"]</FieldLabel>
                            <TextInput @bind-Value="@EditingMenuItem.ElementId" >
                                <Feedback>
                                    <ValidationError />
                                </Feedback>
                            </TextInput>
                        </Field>
                    </Validation>


                    <Validation>
                        <Field>
                            <FieldLabel>@L["CssClass"]</FieldLabel>
                            <TextInput @bind-Value="@EditingMenuItem.CssClass" >
                                <Feedback>
                                    <ValidationError />
                                </Feedback>
                            </TextInput>
                        </Field>
                    </Validation>


                    <div>
                        <Field>
                            <FieldLabel>@L["Permission"]</FieldLabel>
                            @* <TextEdit @bind-Text="@EditingMenuItem.Permission" > *@
                            @*     <Feedback> *@
                            @*         <ValidationError /> *@
                            @*     </Feedback> *@
                            @* </TextEdit> *@
                            <Autocomplete TItem="string"
                                          TValue="string?"
                                          Data="@FilteredPolicyNames"
                                          ReadData="@OnPermissionReadDataAsync"
                                          TotalItems="@FilteredPolicyNames.Count"
                                          TextField="@(( item ) => item)"
                                          ValueField="@((item) => item)"
                                          SelectedValue="@EditingMenuItem.Permission"
                                          SelectedText="@EditPermissionSelectedText"
                                          SelectedValueChanged="@OnEditPermissionValueChangedAsync"
                                          Placeholder="@L["Search"]"
                                          FreeTyping
                                          MinLength="0">
                            </Autocomplete>
                        </Field>
                    </div>


                    <Validation>
                        <Field>
                            <FieldLabel>@L["ResourceTypeName"]</FieldLabel>
                            <TextInput @bind-Value="@EditingMenuItem.ResourceTypeName" >
                                <Feedback>
                                    <ValidationError />
                                </Feedback>
                            </TextInput>
                        </Field>
                    </Validation>

                    <Validation>
                        <Field>
                            <FieldLabel>@L["Component"]</FieldLabel>
                            <TextInput @bind-Value="@EditingMenuItem.Component" >
                                <Feedback>
                                    <ValidationError />
                                </Feedback>
                            </TextInput>
                        </Field>
                    </Validation>
                 


                    
                    
                </Validations>
            </ModalBody>
            <ModalFooter>
                <Button Color="Color.Secondary"
                        Clicked="CloseEditMenuItemModalAsync">
                    @L["Cancel"]
                </Button>
                <SubmitButton Form="CreateMenuItemForm" Clicked="UpdateMenuItemAsync" />
            </ModalFooter>
        </Form>
    </ModalContent>
</Modal>
